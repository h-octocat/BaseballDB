<html>
  <head>
    <link rel="stylesheet" href="css/list-all.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <title>BaseballDB</title>
  </head>
  <body>
    <h2>Search Results</h2>
    <table>
      <tbody>
        <tr>
          <th>Name</th>
          <th>Price</th>
          <th>Team</th>
          <th>Image</th>
        </tr>
        <% for (let i = 0; i < rows.length; i++) { %>
        <tr>
          <td>
            <span><%= rows[i].card_name %></span>
            <button
              class="deleteButton"
              onclick="deleteCard('<%= rows[i].card_id%>')"
            >
              Delete
            </button>
          </td>
          <td>$<%= rows[i].card_price %></td>
          <td><%= rows[i].card_team %></td>
          <td>
            <img
              class="image"
              src="/data?action=retrieve&id=<%= rows[i].card_id %>&user=<%= user %>"
            />
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
    <p class="credit">
      Button from dribble input (if there is one) from uiverse
    </p>
    <script>
      function deleteCard(id) {
        fetch("/data?action=delete&id=" + id, { method: "POST" }).then(
          (res) => {
            if (res == "fail") {
              alert("This card doesn't exist!");
            } else {
              window.location.href = "/";
            }
          }
        );
      }
    </script>
  </body>
</html>
