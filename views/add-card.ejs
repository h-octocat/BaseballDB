<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/add-card.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <title>BaseballDB</title>
  </head>
  <body>
    <h1>Card input system</h1>
    <form action="/add-card" method="post" enctype="multipart/form-data">
      <input
        type="text"
        name="playerName"
        class="input"
        placeholder="Enter player name here"
      />
      <input
        type="text"
        name="cardPrice"
        class="input"
        placeholder="Enter price here"
      />
      <input
        type="text"
        name="playerTeam"
        class="input"
        placeholder="Enter player team here"
      />
      <label class="button" for="file-upload">Input image</label>
      <input type="file" id="file-upload" name="card_image" />
      <button type="submit" name="submit" class="button">Add card</button>
    </form>
    <p class="credit">
      Button from dribble input (if there is one) from uiverse
    </p>
  </body>
</html>
