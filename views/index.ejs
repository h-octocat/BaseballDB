<!DOCTYPE html>
<html lang="en">
  <!-- Do you love easter eggs? If so then you'll love /easter-egg! -->
  <head>
    <link rel="stylesheet" href="css/list-all.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/index.css" />
    <title>BaseballDB</title>
  </head>
  <body>
    <h1>Welcome to BaseballDB, <%= user %></h1>
    <p>
      <% if (cards > 1) { %> You have <%= cards %> cards available. <% } else if
      (cards === 0) { %> No cards in database. <% } else { %> You have 1 card
      available. <% } %>
    </p>
    <p>Your collection's card value is $<%= value %></p>
    <a href="/add-card">Add Cards</a>
    <a href="/all">See All Cards</a>
    <a href="/search">Search By Name</a>
    <a href="/logout">Log out</a>
    <p class="credit">
      Button from dribble input (if there is one) from uiverse
    </p>
  </body>
</html>
